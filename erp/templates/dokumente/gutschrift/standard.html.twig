<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: DejaVu Sans, sans-serif;
      font-size: 9pt;
      color: #1a1a1a;
      padding: 18mm 15mm 30mm 15mm;
    }
    .adressblock-absender {
      font-size: 7pt;
      color: #555;
      border-bottom: 0.5px solid #aaa;
      padding-bottom: 2pt;
      margin-bottom: 3pt;
    }
    .info-raster td {
      padding: 2pt 5pt;
      font-size: 8.5pt;
      vertical-align: top;
    }
    .info-raster td:first-child {
      color: #555;
      white-space: nowrap;
    }
    .info-raster td:last-child {
      font-weight: bold;
    }
    .doc-titel {
      font-size: 16pt;
      font-weight: bold;
      margin: 10pt 0 2pt;
    }
    .doc-referenz {
      font-size: 8.5pt;
      color: #555;
      margin-bottom: 8pt;
    }
    .dankessatz {
      margin-top: 8pt;
      font-size: 8.5pt;
    }
  </style>
</head>
<body>

  {# ── Header ── #}
  {% include '_partials/_header.html.twig' %}

  {# ── Adress- + Info-Block ── #}
  <table style="width:100%; border-collapse:collapse; margin-top:10pt;">
    <tr>
      {# Links: Empfänger-Fenster #}
      <td style="width:50%; vertical-align:top; padding-right:10pt;">
        <div class="adressblock-absender">
          {{ firma.firmenname ?? 'MEALANA KG' }} &middot;
          {{ firma.strasse ?? '' }} &middot;
          {{ firma.plz ?? '' }} {{ firma.ort ?? '' }}
        </div>
        {% set adr = rechnungadr|length ? rechnungadr : kunde %}
        {% if adr.anrede is defined %}<strong>{{ adr.anrede }}</strong><br>{% endif %}
        {% if adr.firmenname is defined and adr.firmenname %}
          <strong>{{ adr.firmenname }}</strong><br>
        {% endif %}
        {{ adr.vorname ?? '' }} {{ adr.nachname ?? (kunde.name ?? '') }}<br>
        {{ adr.strasse ?? '' }}<br>
        {{ adr.plz ?? '' }} {{ adr.ort ?? '' }}<br>
        {% if adr.land is defined and adr.land and adr.land != 'AT' %}
          {{ adr.land }}<br>
        {% endif %}
      </td>

      {# Rechts: Info-Raster #}
      <td style="width:50%; vertical-align:top;">
        <table class="info-raster" style="width:100%; border:1px solid #ccc; border-collapse:collapse;">
          <tr style="background:#f5f5f5;">
            <td style="border-bottom:1px solid #ccc;">Gutschrift-Nr.:</td>
            <td style="border-bottom:1px solid #ccc;">{{ gutschrift.nr }}</td>
          </tr>
          <tr>
            <td style="border-bottom:1px solid #ccc;">Datum:</td>
            <td style="border-bottom:1px solid #ccc;">{{ gutschrift.datum }}</td>
          </tr>
          <tr style="background:#f5f5f5;">
            <td style="border-bottom:1px solid #ccc;">Betrifft Rechnung:</td>
            <td style="border-bottom:1px solid #ccc;">{{ gutschrift.rechnung_nr }}</td>
          </tr>
          <tr>
            <td style="border-bottom:1px solid #ccc;">Auftrags-Nr.:</td>
            <td style="border-bottom:1px solid #ccc;">{{ auftrag.auftrag_nr }}</td>
          </tr>
          {% if auftrag.kunden_id %}
          <tr>
            <td>Kunden-Nr.:</td>
            <td>{{ auftrag.kunden_id }}</td>
          </tr>
          {% endif %}
        </table>
      </td>
    </tr>
  </table>

  {# ── Dokumenttitel ── #}
  <div class="doc-titel">Gutschrift</div>
  <div class="doc-referenz">
    {% if gutschrift.art == 'vollstorno' %}
      Vollstornierung der Rechnung {{ gutschrift.rechnung_nr }}
    {% else %}
      Teilgutschrift zu Rechnung {{ gutschrift.rechnung_nr }}
    {% endif %}
    {% if gutschrift.grund %}
       &mdash; {{ gutschrift.grund }}
    {% endif %}
  </div>

  {# ── Positionen ── #}
  {% include '_partials/_positionen.html.twig' %}

  {# ── Steuerblock + Gesamtbetrag ── #}
  {% include '_partials/_steuerblock.html.twig' %}

  {# ── Hinweis ── #}
  <div class="dankessatz" style="margin-top:12pt;">
    Der Gutschriftbetrag von <strong>{{ summen.brutto_gesamt|number_format(2, ',', '.') }} EUR</strong>
    wird Ihnen {% if auftrag.zahlungsart == 'bar' %}bar ausbezahlt{% else %}auf Ihr Konto rücküberwiesen{% endif %}.
    Bei Fragen stehen wir gerne zur Verfügung.
  </div>

  {# ── Footer ── #}
  {% include '_partials/_footer.html.twig' %}

</body>
</html>
