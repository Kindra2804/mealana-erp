{% extends "mails/basis_layout.html.twig" %}

{% block inhalt %}

<p>Guten Tag,</p>

<p>
    für Ihr Konto bei {{ firmenname }} wurde ein Passwort-Setzen-Link angefordert.
    Klicken Sie auf den folgenden Button, um ein neues Passwort zu vergeben:
</p>

<p style="text-align:center;margin:28px 0">
    <a href="{{ link }}"
       style="background:#2563eb;color:#fff;text-decoration:none;padding:12px 28px;border-radius:6px;font-weight:600;font-size:14px;display:inline-block">
        Passwort setzen
    </a>
</p>

<p style="font-size:12px;color:#888">
    Falls der Button nicht funktioniert, kopieren Sie diesen Link in Ihren Browser:<br>
    <a href="{{ link }}" style="color:#2563eb">{{ link }}</a>
</p>

<p style="font-size:13px;color:#555;margin-top:16px">
    Dieser Link ist {{ gueltigkeit_stunden }} Stunden gültig. Wenn Sie diese Anfrage nicht
    selbst ausgelöst haben, können Sie diese E-Mail ignorieren — es ändert sich nichts an Ihrem Konto.
</p>

<p style="font-size:13px;margin-top:20px">
    Mit freundlichen Grüßen,<br>
    Ihr {{ firmenname }}-Team
</p>

{% endblock %}

{% block footer_extra %}Passwort-Setzen-Link &bull; {% endblock %}
