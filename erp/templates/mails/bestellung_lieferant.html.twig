{% extends "mails/basis_layout.html.twig" %}

{% block inhalt %}

<p>Sehr geehrte Damen und Herren,</p>

<div style="white-space:pre-line; margin:14px 0;">{{ nachricht }}</div>

<p style="font-size:13px;color:#555;margin-top:8px">
    Die Bestellung <strong>{{ bestellnummer }}</strong> finden Sie im Anhang als PDF.
</p>

<p style="font-size:13px;margin-top:20px">
    Mit freundlichen Grüßen,<br>
    Ihr {{ firmenname }}-Team
</p>

{% endblock %}

{% block footer_extra %}Bestellung {{ bestellnummer }} &bull; {% endblock %}
