{% extends "mails/basis_layout.html.twig" %}

{% block inhalt %}

{% if anrede == 'Frau' %}
<p>Sehr geehrte Frau {{ nachname }},</p>
{% elseif anrede == 'Herr' %}
<p>Sehr geehrter Herr {{ nachname }},</p>
{% else %}
<p>Guten Tag{% if kunde_name %} {{ kunde_name }}{% endif %},</p>
{% endif %}

{% if neuer_status == 'bezahlt' %}
<div class="success">
    ✅ <strong>Ihre Zahlung ist vollständig eingegangen – vielen Dank!</strong>
</div>
{% else %}
<div class="hinweis">
    Ihre Teilzahlung ist eingegangen. Der verbleibende Betrag ist noch offen.
</div>
{% endif %}

<p>
    die Zahlung für Ihre Bestellung <strong>{{ auftrag_nummer }}</strong>
    vom {{ buchungsdatum }}
    in Höhe von <strong>{{ betrag_eingegangen|number_format(2, ',', '.') }} EUR</strong>
    ist per {{ zahlungsart_label }} bei uns eingegangen.
</p>

{% if positionen is defined and positionen|length %}
<p style="font-size:12px;font-weight:600;color:#666;margin:20px 0 4px;text-transform:uppercase;letter-spacing:.05em">
    Überblick Ihrer Bestellung
</p>
<table class="table">
    <thead>
        <tr>
            <th>Artikel</th>
            <th style="text-align:right;width:50px">Menge</th>
            <th style="text-align:right;width:90px">Gesamt</th>
        </tr>
    </thead>
    <tbody>
    {% for pos in positionen %}
    <tr>
        <td style="padding:7px 10px;font-size:13px">{{ pos.bezeichnung }}</td>
        <td style="text-align:right;padding:7px 10px;font-size:13px">{{ pos.menge }}</td>
        <td style="text-align:right;padding:7px 10px;font-size:13px">{{ pos.gesamt_brutto|number_format(2, ',', '.') }} EUR</td>
    </tr>
    {% endfor %}
    </tbody>
    <tfoot>
        <tr style="background:#f9fafb;border-top:2px solid #ddd">
            <td colspan="2" style="text-align:right;padding:8px 10px;font-size:12px;color:#666">inkl. MwSt.:</td>
            <td style="text-align:right;padding:8px 10px;font-size:12px;color:#666">{{ mwst_gesamt|number_format(2, ',', '.') }} EUR</td>
        </tr>
        <tr style="background:#f9fafb">
            <td colspan="2" style="text-align:right;padding:8px 10px;font-weight:700">Gesamtsumme:</td>
            <td style="text-align:right;padding:8px 10px;font-weight:700;font-size:15px">{{ brutto_gesamt|number_format(2, ',', '.') }} EUR</td>
        </tr>
        {% if neuer_status == 'teilbezahlt' %}
        <tr style="background:#fff8e1">
            <td colspan="2" style="text-align:right;padding:8px 10px;color:#b45309">Bereits bezahlt:</td>
            <td style="text-align:right;padding:8px 10px;color:#b45309">{{ summe_bezahlt|number_format(2, ',', '.') }} EUR</td>
        </tr>
        <tr style="background:#fff8e1">
            <td colspan="2" style="text-align:right;padding:8px 10px;font-weight:700;color:#b45309">Noch offen:</td>
            <td style="text-align:right;padding:8px 10px;font-weight:700;color:#b45309">{{ offen_betrag|number_format(2, ',', '.') }} EUR</td>
        </tr>
        {% endif %}
    </tfoot>
</table>
{% endif %}

{% if neuer_status == 'bezahlt' %}
<p style="font-size:13px;color:#555;margin-top:16px">
    Der Versand der Ware wird Ihnen gesondert per E-Mail mit Sendungsverfolgung mitgeteilt.
</p>
{% else %}
<p style="font-size:13px;color:#555;margin-top:16px">
    Sobald der gesamte Betrag bei uns eingegangen ist, wird Ihre Bestellung für den Versand vorbereitet.
    Bitte beachten Sie: unbezahlte Bestellungen werden nach 14 Tagen automatisch storniert.
</p>
{% endif %}

<p style="font-size:13px;color:#555;margin-top:16px">
    Bei Fragen stehen wir Ihnen gerne unter
    <a href="mailto:{{ firma_email }}" style="color:#2c3e50">{{ firma_email }}</a> zur Verfügung.
</p>

<p style="font-size:13px;margin-top:20px">
    Mit freundlichen Grüßen,<br>
    Ihr {{ firmenname }}-Team
</p>

{% endblock %}

{% block footer_extra %}Bestellung {{ auftrag_nummer }} &bull; {% endblock %}
